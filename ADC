library IEEE;
use IEEE.STD_LOGIC_1164.ALL;



----------------------------------------------------------------------------------
--						Descripcion de la entidad (Entradas y salidas)
----------------------------------------------------------------------------------
entity OSIOSI is
    Port ( CLK : in STD_LOGIC;
			  out_clk: out STD_LOGIC;
			  OUT_CLK_UPDATE: out STD_LOGIC;
			  OUTPUT_LCD : out STD_LOGIC_VECTOR(3 DOWNTO 0);
			  ENABLE_LCD : out STD_LOGIC;
			  RS_LCD : out STD_LOGIC;
			  Out_CLK_LCD : out STD_LOGIC);
end OSIOSI;
--










----------------------------------------------------------------------------------
--											Arquitectura
----------------------------------------------------------------------------------
architecture Behavioral of OSIOSI is
--					----------------------------------------------------
--								Constantes y Señales por Proceso
--					----------------------------------------------------

-----------------------------------------
-- 				CLOCK_ADC
-----------------------------------------
--Constantes:
CONSTANT HALF_CLK_ADC: INTEGER:= 39; 

--Señales:
SIGNAL CONT_ADC : INTEGER := 0;
SIGNAL FLAG_ADC : STD_LOGIC:= '0';




-----------------------------------------
-- 				CLOCK_UPDATE
-----------------------------------------
--Constantes:
CONSTANT HALF_CLK_UPDATE: INTEGER:= 1_000_000; --Duración en cliclos de Reloj del medio periodo

--Señales:
SIGNAL CONTA_UPDATE : INTEGER := 0;
SIGNAL FLAG_UPDATE : STD_LOGIC:= '0';



-----------------------------------------
-- 				CLOCK_LCD
-----------------------------------------
--Constantes:
CONSTANT HALF_CLK_LCD: INTEGER:= 25; --Duración en cliclos de Reloj del medio periodo de 1us/2 = 500ns = 25 CM

--Señales:
SIGNAL CONTA_CLK_LCD : INTEGER := 0;
SIGNAL CLK_LCD : STD_LOGIC:= '0';
--



-----------------------------------------
-- 				INI_LCD
-----------------------------------------
--Constantes:
--CONSTANT HALF_CLK_LCD: INTEGER:= 25; --Duración en cliclos de Reloj del medio periodo de 1us/2 = 500ns = 25 CM

--Señales:
SIGNAL US_TRASCURRIDOS : INTEGER := 0; -- AL NO ESPECIFICAR RANGO EL SINTETIZADOR LO HARÁ DE 32 BITS

SIGNAL OUTPUT_LCD_SIGNALS : STD_LOGIC_VECTOR(3 DOWNTO 0) := "0000";
SIGNAL ENABLE_LCD_SIGNAL : STD_LOGIC := '0';
SIGNAL RS_LCD_SIGNAL : STD_LOGIC := '0';
SIGNAL CLK_NOW : STD_LOGIC := '0';
SIGNAL CLK_LCD_BEFORE : STD_LOGIC := '0';
SIGNAL DEPURA : STD_LOGIC := '0';









begin
----------------------------------------------------------------------------------




--					----------------------------------------------------
--												PROCESOS
--					----------------------------------------------------

-----------------------------------------
-- 				CLOCK_ADC
-----------------------------------------
CLOCK_ADC:process(CLK)

begin
    IF rising_edge(CLK) then --
        IF CONT_ADC =  HALF_CLK_ADC then
           CONT_ADC <= 0;
           FLAG_ADC <= NOT FLAG_ADC;
        else
            CONT_ADC <= CONT_ADC + 1;
        end if;

    END IF;
END process;
-- ASIGNACIONES DIRECTAS ASOCIADAS:
OUT_clk <= FLAG_ADC;

--



-----------------------------------------
-- 				CLOCK_UPDATE
-----------------------------------------
CLOCK_UPDATE:process(CLK)

begin
    IF rising_edge(CLK) then --

        IF CONTA_UPDATE =  HALF_CLK_UPDATE then
           CONTA_UPDATE <= 0;
           FLAG_UPDATE <= NOT FLAG_UPDATE;
        else
            CONTA_UPDATE <= CONTA_UPDATE + 1;
        end if;

    END IF;
END process;
-- ASIGNACIONES DIRECTAS ASOCIADAS:
OUT_CLK_UPDATE <= FLAG_UPDATE;

--




-----------------------------------------
-- 				CLOCK_LCD
-----------------------------------------
--Descipcion: Reloj cuya frecuencia es de 1000 ns = 1us =  50 CM
CLOCK_LCD:process(CLK)

begin
    IF rising_edge(CLK) then

        IF CONTA_CLK_LCD =  HALF_CLK_LCD then
           CONTA_CLK_LCD <= 0;
           CLK_LCD <= NOT CLK_LCD;
        else
            CONTA_CLK_LCD <= CONTA_CLK_LCD + 1;
        end if;

    END IF;
END process;
-- ASIGNACIONES DIRECTAS ASOCIADAS:
--OUT_CLK_LCD <= CLK_LCD;

--




-----------------------------------------
-- 				INI_LCD
-----------------------------------------
-- Descipcion: Maquina de estados FINITA que Arranca la LCD 
-- con los pasos que indicados por el fabricante:
-- 1-. Hand Shake
-- 2-. Inicializa la LCD con una comunicación a 4 bits (D4-D7)
-- 3-. Enciende la LCD.


INI_LCD:process(CLK)
begin
	IF RISING_EDGE(CLK) THEN
		CLK_LCD_BEFORE <= CLK_NOW;
		CLK_NOW <= CLK_LCD;
		-- CADA QUE TRANSCURRA 1 us:
		IF CLK_LCD_BEFORE = '0' AND CLK_NOW = '1' then 
		DEPURA  <= NOT(DEPURA);
		-- Incrementamos el tiempo siempre que hay un pulso
		IF US_TRASCURRIDOS > 1_000_000 THEN
			NULL;
		ELSE
			US_TRASCURRIDOS <= US_TRASCURRIDOS + 1;
		END IF;
		CASE US_TRASCURRIDOS IS
				--Espera 100 ms a que se estabilice el voltaje de la LCD:
				WHEN 100_000 =>
				------------------------------------------------------
				--						1-. HAND SHAKE:
				------------------------------------------------------
					RS_LCD_SIGNAL <= '0'; --RS = '0' -> MANDAR COMANDO
					OUTPUT_LCD_SIGNALS <= "0011";
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
				WHEN 100_005 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					--ESPERA 5ms
				WHEN 107_005 =>
					RS_LCD_SIGNAL <= '0'; --RS = '0' -> MANDAR COMANDO
					OUTPUT_LCD_SIGNALS <= "0011";
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
				WHEN 107_010 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2MS
					--ESPERA 5ms 
