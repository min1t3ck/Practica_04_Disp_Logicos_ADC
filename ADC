					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 123_025 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 125_025 =>
					OUTPUT_LCD_SIGNALS <= "1000";	--N = '1' -> a dos renglones; F = '0' -> formato de 5x7 pixeles
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 125_030 =>
