					RS_LCD_SIGNAL <= '0'; --RS = '0' -> MANDAR COMANDO
					OUTPUT_LCD_SIGNALS <= "0011";
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
				WHEN 114_015 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2MS
					--ESPERA 5ms 
				WHEN 121_015 =>
				------------------------------------------------------
				--					2-. INICIALIZACIÓN LCD:
				------------------------------------------------------
					RS_LCD_SIGNAL <= '0'; --RS = '0' -> MANDAR COMANDO
					OUTPUT_LCD_SIGNALS <= "0010"; -- -> INDICA QUE SE USARÁ UN BUS DE 4 BITS
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 121_020 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 123_020 =>
					
