					WHEN 141_065 =>
					OUTPUT_LCD_SIGNALS <= "1111";	-- D ='0' -> ON DISPLAY; C = '1' -> ACTIVA CURSOR; B = '1' -> CURSOR CON PARPADEO
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 141_070 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 143_070 =>
					--}
					
					--PRUEBA. ESCRIBE EL CARACTER "A"
			
					RS_LCD_SIGNAL <= '1'; --RS = '1' -> MANDAR CARACTER
