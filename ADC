					WHEN 127_030 =>
					--}
					
					--FUNCTION_DISPLAY_OFF(00001DCB){
					RS_LCD_SIGNAL <= '0'; --RS = '0' -> MANDAR COMANDO
					OUTPUT_LCD_SIGNALS <= "0000"; -- -> INDICA FUNCION_SET: TRABJA A 4 BITS
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 127_035 =>
