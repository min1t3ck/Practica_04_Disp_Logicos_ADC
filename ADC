					--ESPERA 2ms
					WHEN 129_035 =>
					OUTPUT_LCD_SIGNALS <= "1000";	-- D ='0' -> APAGA DISPLAY; C = '1' -> ACTIVA CURSOR; B = '1' -> CURSOR CON PARPADEO
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 129_040 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 131_040 =>
					--}
					
					
