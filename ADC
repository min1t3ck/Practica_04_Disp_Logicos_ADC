					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 137_055 =>
					OUTPUT_LCD_SIGNALS <= "0110";	-- S ='1' -> CADA QUE SE ESCRIBE UN DATO, LA MEMORIA SE RECORRE; T = '1' -> CADA QUE ESCRIBE UN DATO. SE INCREMENTA EN 1 EL APUNTADOR DE LA RAM
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 137_060 =>
