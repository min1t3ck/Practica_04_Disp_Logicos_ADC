					--ESPERA 2ms
					WHEN 149_085 =>
					OUTPUT_LCD_SIGNALS <= "0100";	-- D ='0' -> ON DISPLAY; C = '1' -> ACTIVA CURSOR; B = '1' -> CURSOR CON PARPADEO
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 149_090 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 151_090 =>
					
					--}
					
					-- ESCRIBE CARACTER "C"
					RS_LCD_SIGNAL <= '1'; --RS = '1' -> MANDAR CARACTER
					OUTPUT_LCD_SIGNALS <= "0100"; -- -> NIBBLE ALTO
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 151_095 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 153_095 =>
					OUTPUT_LCD_SIGNALS <= "0011";	-- -> NIBBLE BAJO
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 153_100 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 155_100 =>
					
					--}
					
					--FUNCTION_SET_DRAM_ADRESS(EN EXADECIMAL){
					RS_LCD_SIGNAL <= '0'; --RS = '' -> MANDAR COMANDO
					OUTPUT_LCD_SIGNALS <= "1100"; -- -> NIBBLE ALTO ADD
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 155_105 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 157_105 =>
					OUTPUT_LCD_SIGNALS <= "0100"; -- -> NIBBLE BAJO ADDRES
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 157_110 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 159_110 =>
					--}
					
					
					
					-- ESCRIBE CARACTER "0"
					RS_LCD_SIGNAL <= '1'; --RS = '1' -> MANDAR CARACTER
					OUTPUT_LCD_SIGNALS <= "0011"; -- -> NIBBLE ALTO
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 159_115 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 161_115 =>
					OUTPUT_LCD_SIGNALS <= "0000";	-- -> NIBBLE BAJO
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 161_120 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 163_120 =>
					
					-- ESCRIBE CARACTER "0"
					RS_LCD_SIGNAL <= '1'; --RS = '1' -> MANDAR CARACTER
					OUTPUT_LCD_SIGNALS <= "0011"; -- -> NIBBLE ALTO
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 163_125 =>
