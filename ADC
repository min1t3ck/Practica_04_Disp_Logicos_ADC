					--ESPERA 5us
					WHEN 145_080 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 147_080 =>
					
					--}
					
					-- ESCRIBE CARACTER "D"
