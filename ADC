					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
					--ESPERA 5us
					WHEN 131_045 =>
					ENABLE_LCD_SIGNAL <= '0'; --DESACTIVA ENABLE
					--ESPERA 2ms
					WHEN 133_045 =>
					OUTPUT_LCD_SIGNALS <= "0001";	-- D ='0' -> APAGA DISPLAY; C = '1' -> ACTIVA CURSOR; B = '1' -> CURSOR CON PARPADEO
					ENABLE_LCD_SIGNAL <= '1'; --ACTIVA ENABLE
